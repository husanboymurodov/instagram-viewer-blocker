{
  "manifest_version": 3,
  "name": "Instagram Blocker",
  "version": "1.0.0",
  "description": "Block Instagram accounts — even ones that blocked you first.",
  "permissions": ["cookies", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; img-src 'self' https://*.cdninstagram.com https://*.fbcdn.net data: blob:;"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ig-blocker@husanboy",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Instagram Blocker",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
